{
  "family": "poc-agenda-web-task",
  "containerDefinitions": [
    {
      "name": "web-container",
      "image": "557643339346.dkr.ecr.us-east-1.amazonaws.com/poc-agenda-web:latest",
      "cpu": 256,
      "memoryReservation": 256,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp",
          "name": "web-80-tcp",
          "appProtocol": "http"
        }
      ],
      "essential": true,
      "environment": [],
      "environmentFiles": [],
      "mountPoints": [],
      "volumesFrom": [],
      "ulimits": [],
      "systemControls": []
    }
  ],
  "executionRoleArn": "arn:aws:iam::557643339346:role/ecsTaskExecutionRole",
  "networkMode": "bridge",
  "volumes": [],
  "placementConstraints": [],
  "requiresCompatibilities": [
    "EC2"
  ],
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  }
}